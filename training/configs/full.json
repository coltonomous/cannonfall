{
  "mode": "CASTLE",
  "max_turns": 30,
  "layout_generator": "curriculum",
  "opponent_policy": "heuristic",
  "opponent_noise": 0.15,
  "opponent_noise_end": 0.04,
  "difficulty": 0.1,
  "fast_physics": true,
  "total_timesteps": 500000,

  "curriculum_start": 0.1,
  "curriculum_end": 1.0,
  "curriculum_ramp_frac": 0.6,

  "learning_rate": 3e-4,
  "n_steps": 2048,
  "batch_size": 64,
  "n_epochs": 10,
  "gamma": 0.99,
  "gae_lambda": 0.95,
  "clip_range": 0.2,
  "ent_coef": 0.01,

  "policy_kwargs": {
    "net_arch": [256, 128]
  },

  "checkpoint_freq": 50000,
  "eval_freq": 25000,
  "eval_episodes": 10
}
